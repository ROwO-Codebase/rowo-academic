# Non-secret local/runtime configuration. These defaults mirror wrangler.jsonc.
APP_ENV=development
ROWO_WEB_ORIGIN=https://rowo.link
ROWO_API_ORIGIN=https://api.rowo.link
ACADEMIC_CATALOG_ID=663290e835aff7001cc62323
ACADEMIC_CALENDAR_LABEL=2026

# D1 resources are runtime bindings, not environment variables:
#   DB            app-owned programs, plans, course history, and sessions
#   ACADEMIC_DB   query-only academic-calendar reference data
#
# This SSO flow has no OAuth client secret or session-signing secret. The
# Academic Worker validates the transient upstream JWT server-side, discards it,
# and persists only a hashed opaque session token in DB.

# Optional read-only REST fallback for hosting environments that cannot attach
# a second D1 binding. Keep the API token in a secret store, never in this file.
# ACADEMIC_DB_ID=578d593a-d00d-4723-b3de-0659e2388415
# CF_ACCOUNT_ID=
# CF_D1_API_TOKEN=
